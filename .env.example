# ===========================================
# Root .env — used by docker-compose.prod.yml
# ===========================================
# Copy to .env and fill in values. See backend/.env.example for full reference.

# Production database credentials
POSTGRES_USER=agentml
POSTGRES_PASSWORD=
POSTGRES_DB=agentml

# Redis password
REDIS_PASSWORD=

# Public URL where the backend API is accessible (used to build the frontend)
BACKEND_PUBLIC_URL=http://localhost:8000
