# ===========================================
# AgentML Backend Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Application
DEBUG=false

# ===========================================
# Database (Required)
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_ml

# ===========================================
# Redis / Celery (Required)
# ===========================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===========================================
# LLM API (Required for AI features)
# ===========================================
# OpenAI API key (or compatible provider)
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1

# ===========================================
# Modal.com Cloud Training (Optional)
# ===========================================
# Get tokens from: https://modal.com/settings
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# ===========================================
# CORS (Required for frontend)
# ===========================================
# Add your production frontend URL here
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ===========================================
# Authentication (Required for production)
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ===========================================
# API Key Encryption (Recommended for production)
# ===========================================
# Encrypts stored LLM API keys in the database.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_LLM_PER_MINUTE=10

# ===========================================
# Google OAuth (Optional)
# ===========================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# Email/SMTP (Optional - for sharing invitations)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AgentML

# ===========================================
# Frontend URL (for email links)
# ===========================================
FRONTEND_URL=http://localhost:5173
