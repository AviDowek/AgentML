# ===========================================
# AgentML Backend Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Application
DEBUG=false

# ===========================================
# Database (Required)
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentic_ml

# ===========================================
# Redis / Celery (Required)
# ===========================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===========================================
# LLM API (Required for AI features)
# ===========================================
# OpenAI API key (or compatible provider)
LLM_API_KEY=your-api-key-here
LLM_API_BASE_URL=https://api.openai.com/v1

# Optional: Default model to use
# LLM_MODEL=gpt-4o

# ===========================================
# Modal.com Cloud Training (Optional)
# ===========================================
# Get tokens from: https://modal.com/settings
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# ===========================================
# CORS (Required for frontend)
# ===========================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ===========================================
# Authentication (Required)
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# ===========================================
# Google OAuth (Optional)
# ===========================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# Email/SMTP (Optional - for sharing invitations)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=AgentML

# ===========================================
# Frontend URL (for email links)
# ===========================================
FRONTEND_URL=http://localhost:5173
